{
  "expo": {
    "name": "ENZIRA App",
    "slug": "enzira-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFAED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karina751.enziraapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFAED"
      },
      "package": "com.karina751.enziraapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ENZIRA necesita acceso a tus fotos para que puedas cargar los nuevos modelos de la colección.",
          "cameraPermission": "ENZIRA necesita acceso a la cámara para capturar las carteras nuevas al instante."
        }
      ]
    ]
  }
}